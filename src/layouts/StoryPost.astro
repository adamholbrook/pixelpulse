---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'sideQuests'>['data'];

const { title, description, pubDate, author, heroImage, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | Side Quests | PixelPulse`} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<div class="story-hero">
				{heroImage && (
					<Image
						src={heroImage}
						alt={title}
						width={1200}
						height={500}
						class="hero-img"
					/>
				)}
				<div class="hero-overlay">
					<div class="hero-section-label">Side Quests</div>
					{tags.length > 0 && (
						<div class="hero-tags">
							{tags.map((tag) => <span class="tag">{tag}</span>)}
						</div>
					)}
					<h1>{title}</h1>
					<p class="hero-desc">{description}</p>
					<div class="hero-byline">
						<span>By <strong>{author}</strong></span>
						<span class="separator">·</span>
						<FormattedDate date={pubDate} />
					</div>
				</div>
			</div>

			<article class="story-article container">
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.story-hero {
		position: relative;
		height: 480px;
		overflow: hidden;
		background-color: #0a0a0a;
	}

	.hero-img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: brightness(0.28);
		border-radius: 0;
	}

	.hero-overlay {
		position: relative;
		z-index: 1;
		max-width: 800px;
		margin: 0 auto;
		padding: 3rem 1.5rem;
		height: 100%;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		text-align: center;
		align-items: center;
	}

	.hero-section-label {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	.hero-tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: center;
		margin-bottom: 1rem;
	}

	.tag {
		display: inline-block;
		padding: 0.2rem 0.65rem;
		background-color: rgba(255, 255, 255, 0.1);
		color: rgba(255, 255, 255, 0.75);
		border: 1px solid rgba(255, 255, 255, 0.15);
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		border-radius: 4px;
	}

	.hero-overlay h1 {
		font-size: clamp(1.8rem, 4vw, 3rem);
		color: #fff;
		margin-bottom: 0.75rem;
		line-height: 1.15;
		text-align: center;
		max-width: 680px;
	}

	.hero-desc {
		color: rgba(255, 255, 255, 0.65);
		font-size: 1rem;
		max-width: 580px;
		margin-bottom: 1.25rem;
		line-height: 1.6;
		text-align: center;
		font-style: italic;
	}

	.hero-byline {
		color: rgba(255, 255, 255, 0.5);
		font-size: 0.85rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.hero-byline strong {
		color: rgba(255, 255, 255, 0.8);
	}

	.separator {
		color: rgba(255, 255, 255, 0.25);
	}

	.story-article {
		padding: 4rem 1.5rem 5rem;
		max-width: 760px;
	}

	.prose {
		color: var(--text-secondary);
		font-size: 1.05rem;
		line-height: 1.85;
	}

	.prose :global(h2) {
		color: var(--text-primary);
		font-size: 1.35rem;
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
		letter-spacing: -0.01em;
	}

	.prose :global(h3) {
		color: var(--text-primary);
		font-size: 1.1rem;
		margin-top: 2rem;
		margin-bottom: 0.5rem;
	}

	.prose :global(p) {
		color: var(--text-secondary);
		margin-bottom: 1.5em;
	}

	.prose :global(hr) {
		border-color: var(--border);
		margin: 2.5rem auto;
		max-width: 120px;
	}

	.prose :global(em) {
		color: var(--text-muted);
	}

	.prose :global(blockquote) {
		border-left-color: var(--accent);
		margin-left: 0;
	}

	@media (max-width: 600px) {
		.story-hero {
			height: 400px;
		}
	}
</style>
