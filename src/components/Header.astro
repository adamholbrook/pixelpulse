---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="header-inner">
		<a href="/" class="site-logo">{SITE_TITLE}</a>
		<nav class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/reviews">Reviews</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background-color: #111;
		border-bottom: 2px solid var(--accent);
	}

	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.site-logo {
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: -0.02em;
		color: #fff;
		text-decoration: none;
		text-transform: uppercase;
		flex-shrink: 0;
	}

	.site-logo span {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	@media (max-width: 640px) {
		.site-logo {
			font-size: 1.2rem;
		}
	}
</style>
