---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;
const stories = (await getCollection('sideQuests')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<html lang="en">
	<head>
		<BaseHead title={`Side Quests | ${SITE_TITLE}`} description="Creative writing from the PixelPulse crew — stories, fiction, and everything in between." />
	</head>
	<body>
		<Header />
		<main>
			<div class="section-hero">
				<div class="container">
					<div class="section-label">✍️ Side Quests</div>
					<h1>Creative Writing</h1>
					<p class="section-desc">Stories, fiction, and words we wanted to put somewhere. The optional content that's actually worth doing.</p>
				</div>
			</div>

			<div class="container stories-grid">
				{stories.length === 0 && (
					<p class="empty">No stories yet — check back soon.</p>
				)}
				{stories.map((story) => (
					<a href={`${base}side-quests/${story.id}`} class="story-card">
						<div class="card-image">
							{story.data.heroImage ? (
								<Image
									src={story.data.heroImage}
									alt={story.data.title}
									width={600}
									height={338}
								/>
							) : (
								<div class="card-image-placeholder" />
							)}
						</div>
						<div class="card-body">
							{story.data.tags.length > 0 && (
								<div class="card-tags">
									{story.data.tags.map((tag) => (
										<span class="tag">{tag}</span>
									))}
								</div>
							)}
							<h2 class="card-title">{story.data.title}</h2>
							<p class="card-desc">{story.data.description}</p>
							<div class="card-footer">
								<span class="author">By {story.data.author}</span>
								<FormattedDate date={story.data.pubDate} />
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.section-hero {
		background: linear-gradient(180deg, #0d0f0d 0%, var(--bg-primary) 100%);
		border-bottom: 1px solid rgba(0, 230, 118, 0.1);
		padding: 3.5rem 0 2.5rem;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--accent);
		margin-bottom: 0.75rem;
	}

	.section-hero h1 {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		margin-bottom: 0.6rem;
	}

	.section-desc {
		color: var(--text-secondary);
		font-size: 1rem;
		margin: 0;
		max-width: 520px;
	}

	.stories-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
		gap: 1.5rem;
		padding: 3rem 1.5rem 5rem;
	}

	.empty {
		color: var(--text-muted);
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem 0;
	}

	.story-card {
		display: flex;
		flex-direction: column;
		background-color: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.story-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}

	.card-image {
		aspect-ratio: 16/9;
		overflow: hidden;
		background-color: var(--bg-secondary);
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.3s;
	}

	.story-card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-image-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #0d0f0d, var(--bg-card));
	}

	.card-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.card-tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
	}

	.tag {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.15rem 0.5rem;
		border-radius: 3px;
		background-color: rgba(0, 230, 118, 0.12);
		color: var(--accent);
		border: 1px solid rgba(0, 230, 118, 0.2);
	}

	.card-title {
		font-size: 1.15rem;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.35;
	}

	.card-desc {
		font-size: 0.875rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		font-style: italic;
	}

	.card-footer {
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.author {
		color: var(--text-secondary);
	}
</style>
