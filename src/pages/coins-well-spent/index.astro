---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('coinsWellSpent')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function scoreTier(score: number) {
	if (score >= 9) return 'masterpiece';
	if (score >= 7) return 'great';
	if (score >= 5) return 'decent';
	if (score >= 3) return 'mixed';
	return 'poor';
}
---

<html lang="en">
	<head>
		<BaseHead title={`Coins Well Spent | ${SITE_TITLE}`} description="Revisiting the classics — reviews of older games that still hold up." />
	</head>
	<body>
		<Header />
		<main>
			<div class="section-hero">
				<div class="container">
					<div class="section-label">🪙 Coins Well Spent</div>
					<h1>Classic Game Reviews</h1>
					<p class="section-desc">Revisiting the games that shaped the medium. Old coins, still shining.</p>
				</div>
			</div>

			<div class="container reviews-grid">
				{entries.length === 0 && (
					<p class="empty">No reviews yet — check back soon.</p>
				)}
				{entries.map((entry) => (
					<a href={`${base}coins-well-spent/${entry.id}`} class="review-card">
						<div class="card-image">
							{entry.data.heroImage ? (
								<Image
									src={entry.data.heroImage}
									alt={entry.data.title}
									width={600}
									height={338}
								/>
							) : (
								<div class="card-image-placeholder" />
							)}
							<div class="card-score score-badge" data-tier={scoreTier(entry.data.score)}>
								{entry.data.score.toFixed(1)}
							</div>
							<div class="card-year">{entry.data.originalRelease}</div>
						</div>
						<div class="card-body">
							<div class="card-meta">
								<span class="card-genre">{entry.data.genre}</span>
								<span class="card-platform">{entry.data.platform}</span>
							</div>
							<h2 class="card-title">{entry.data.title}</h2>
							<p class="card-desc">{entry.data.description}</p>
							<div class="card-footer">
								<span class="reviewer">By {entry.data.reviewerName}</span>
								<FormattedDate date={entry.data.pubDate} />
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.section-hero {
		background: linear-gradient(180deg, #1a1500 0%, var(--bg-primary) 100%);
		border-bottom: 1px solid rgba(255, 215, 0, 0.15);
		padding: 3.5rem 0 2.5rem;
	}

	.section-label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--score-gold);
		margin-bottom: 0.75rem;
	}

	.section-hero h1 {
		font-size: clamp(1.8rem, 4vw, 2.8rem);
		margin-bottom: 0.6rem;
	}

	.section-desc {
		color: var(--text-secondary);
		font-size: 1rem;
		margin: 0;
	}

	.reviews-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 1.5rem;
		padding: 3rem 1.5rem 5rem;
	}

	.empty {
		color: var(--text-muted);
		grid-column: 1 / -1;
		text-align: center;
		padding: 3rem 0;
	}

	.review-card {
		display: flex;
		flex-direction: column;
		background-color: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.review-card:hover {
		border-color: var(--score-gold);
		transform: translateY(-2px);
		box-shadow: 0 4px 24px rgba(255, 215, 0, 0.08);
	}

	.card-image {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
		background-color: var(--bg-secondary);
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.3s;
		filter: sepia(0.2);
	}

	.review-card:hover .card-image img {
		transform: scale(1.03);
		filter: sepia(0);
	}

	.card-image-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, #1a1500, var(--bg-card));
	}

	.card-score {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		width: 48px;
		height: 48px;
		font-size: 1.1rem;
	}

	.card-year {
		position: absolute;
		bottom: 0.6rem;
		left: 0.6rem;
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--score-gold);
		background-color: rgba(0, 0, 0, 0.7);
		padding: 0.2rem 0.5rem;
		border-radius: 3px;
		letter-spacing: 0.05em;
	}

	.card-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.card-meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.card-genre,
	.card-platform {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
	}

	.card-genre {
		background-color: var(--accent);
		color: #000;
	}

	.card-platform {
		background-color: var(--bg-secondary);
		color: var(--text-secondary);
		border: 1px solid var(--border);
	}

	.card-title {
		font-size: 1.2rem;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
	}

	.card-desc {
		font-size: 0.875rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-footer {
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.reviewer {
		color: var(--text-secondary);
	}
</style>
