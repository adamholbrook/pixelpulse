---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const reviews = (await getCollection('reviews')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function scoreTier(score: number) {
	if (score >= 9) return 'masterpiece';
	if (score >= 7) return 'great';
	if (score >= 5) return 'decent';
	if (score >= 3) return 'mixed';
	return 'poor';
}
---

<html lang="en">
	<head>
		<BaseHead title={`Reviews | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="container page-header">
				<h1>All Reviews</h1>
				<p>{reviews.length} review{reviews.length !== 1 ? 's' : ''}</p>
			</div>

			<div class="container reviews-grid">
				{reviews.map((review) => (
					<a href={`${base}/reviews/${review.id}`} class="review-card">
						<div class="card-image">
							{review.data.heroImage ? (
								<Image
									src={review.data.heroImage}
									alt={review.data.title}
									width={600}
									height={338}
								/>
							) : (
								<div class="card-image-placeholder" />
							)}
							<div class="card-score score-badge" data-tier={scoreTier(review.data.score)}>
								{review.data.score.toFixed(1)}
							</div>
						</div>
						<div class="card-body">
							<div class="card-meta">
								<span class="card-genre">{review.data.genre}</span>
								<span class="card-platform">{review.data.platform}</span>
							</div>
							<h2 class="card-title">{review.data.title}</h2>
							<p class="card-desc">{review.data.description}</p>
							<div class="card-footer">
								<span class="reviewer">By {review.data.reviewerName}</span>
								<FormattedDate date={review.data.pubDate} />
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: 3rem 1.5rem 2rem;
	}

	.page-header h1 {
		font-size: 2.5rem;
		margin-bottom: 0.25rem;
	}

	.page-header p {
		color: var(--text-secondary);
		font-size: 0.9rem;
		margin: 0;
	}

	.reviews-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 1.5rem;
		padding: 0 1.5rem 4rem;
	}

	.review-card {
		display: flex;
		flex-direction: column;
		background-color: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
	}

	.review-card:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
	}

	.card-image {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
		background-color: var(--bg-secondary);
	}

	.card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.3s;
	}

	.review-card:hover .card-image img {
		transform: scale(1.03);
	}

	.card-image-placeholder {
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, var(--bg-secondary), var(--bg-card));
	}

	.card-score {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		width: 48px;
		height: 48px;
		font-size: 1.1rem;
	}

	.card-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		flex: 1;
	}

	.card-meta {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.card-genre,
	.card-platform {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.2rem 0.6rem;
		border-radius: 4px;
	}

	.card-genre {
		background-color: var(--accent);
		color: #fff;
	}

	.card-platform {
		background-color: var(--bg-secondary);
		color: var(--text-secondary);
		border: 1px solid var(--border);
	}

	.card-title {
		font-size: 1.2rem;
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
	}

	.card-desc {
		font-size: 0.875rem;
		color: var(--text-secondary);
		margin: 0;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.card-footer {
		margin-top: auto;
		padding-top: 0.75rem;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.8rem;
		color: var(--text-muted);
	}

	.reviewer {
		color: var(--text-secondary);
	}
</style>
